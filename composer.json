{
  "name": "meisterwerk/bq-utils",
  "description": "Handy utils that make working with the booqable-api easier.",
  "license": "MIT",
  "require": {
    "php": ">=8.2",
    "ext-curl": "*",
    "meisterwerk/core": "^1.0",
    "whatwedo/php-coding-standard": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "Meisterwerk\\BqUtils\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
